# 비전드림 홈페이지 환경변수 (Vercel Project Settings에 입력)

# ConvertKit (전자책 이메일 구독 + 너처 시퀀스)
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=
# (선택) 유입 세그먼트 태그 id
CONVERTKIT_TAG_ID=

# ── 로그인/역할 대시보드 (앱과 SSO 연동) ──
# 앱(vision-manager-app)과 반드시 동일한 값. 세션 JWT(app_session_id) 검증용. 서버 전용.
JWT_SECRET=
# 앱과 동일한 Supabase Postgres 직결 (public.users 등 읽기). Supabase 풀러(6543) 권장.
DATABASE_URL=
# 로그인 처리/복귀 도메인
NEXT_PUBLIC_APP_BASE_URL=https://app.visiondream.kr
NEXT_PUBLIC_SITE_URL=https://visiondream.kr
# 전자책 리더(이어보기 링크용)
NEXT_PUBLIC_EBOOK_BASE_URL=https://book.visiondream.kr

# (Phase 2) Supabase 클라이언트가 필요할 경우
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
